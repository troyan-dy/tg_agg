# --- Telegram ---
# Bot token from @BotFather
BOT_TOKEN=123456:ABC-your-token-here
# Channel the bot posts to: "@channelusername" or numeric "-100...".
# The bot must be an administrator of the channel with the right to post.
CHANNEL_ID=@my_channel
# Telegram user id allowed to control the bot (get it from @userinfobot)
ADMIN_ID=123456789

# --- DeepSeek (OpenAI-compatible API) ---
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- RSS ---
# Optional fallback feed URL. The url set via chat (/setrss, stored in the DB)
# always wins; this value is used only when nothing is stored yet — handy for
# local testing. Leave empty in prod and configure the feed via the chat.
RSS_URL=

# --- Storage (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://tg:tg@localhost:5432/tg_agg

# --- Logging ---
# Level for the app's loggers: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Scheduler ---
# Hours of the day (in TIMEZONE) when the pipeline runs
TIMEZONE=UTC
RUN_HOURS=9,13,18
RUN_ON_STARTUP=false

# --- Pipeline ---
MAX_CANDIDATES=20
POST_LANGUAGE=русском
