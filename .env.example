# --- Telegram ---
# Bot token from @BotFather
BOT_TOKEN=123456:ABC-your-token-here
# Telegram user id allowed to control the bot (get it from @userinfobot).
# Channels are added from the chat (send the bot a channel link); there is no
# single CHANNEL_ID anymore — the bot can run several channels at once. For each
# channel the bot must be an administrator with the right to post.
ADMIN_ID=123456789

# --- DeepSeek (OpenAI-compatible API) ---
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- Storage (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://tg:tg@localhost:5432/tg_agg

# --- Logging ---
# Level for the app's loggers: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Scheduler ---
# TIMEZONE is how a channel's run hours are interpreted. RUN_HOURS is only the
# DEFAULT schedule seeded into a newly added channel; each channel then keeps
# its own hours (set via chat /sethours).
TIMEZONE=UTC
RUN_HOURS=9,13,18
RUN_ON_STARTUP=false

# --- Pipeline ---
MAX_CANDIDATES=20
POST_LANGUAGE=русском
# Default post tone for a newly added channel: news | expert | casual | ironic |
# hype | digest. Each channel then keeps its own tone (set via chat /settone).
POST_TONE=news
